#!/usr/bin/env bash
# ==============================================================================
# swarf — reclaim a Mac developer's disk space, safely.
#
# Scans your code trees for build artifacts (node_modules, target, build, .gradle,
# __pycache__, Pods, …) AND the Apple-specific junk other cleaners ignore
# (Xcode DerivedData, iOS DeviceSupport, Simulator caches, CocoaPods, SwiftPM).
#
# Two things make swarf different from `rm -rf`:
#   1. Trash-first  — everything moves to ~/.Trash, recoverable. Nothing is
#                     permanently deleted unless you pass --delete.
#   2. Marker-verified — a folder named `node_modules` is only ever touched when
#                     its parent actually holds a package.json (a `target` needs a
#                     Cargo.toml, etc.). swarf never deletes a folder just because
#                     of its name.
#
# Usage:
#   swarf scan  [roots...] [filters]      # read-only; show what's reclaimable
#   swarf clean [roots...] [filters]      # move matches to Trash (asks first)
#   swarf --help
#
# It's one auditable Bash file. Read it before you run it.
# ==============================================================================
set -euo pipefail

readonly SWARF_VERSION="0.1.0"
readonly SELF_NAME="swarf"
readonly TRASH_DIR="${HOME}/.Trash"

# ------------------------------------------------------------------------------
# Colors (respect NO_COLOR)
# ------------------------------------------------------------------------------
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
    C_RESET=$'\033[0m'; C_DIM=$'\033[2m'; C_BOLD=$'\033[1m'
    C_CYAN=$'\033[36m'; C_GREEN=$'\033[32m'; C_YELLOW=$'\033[33m'; C_RED=$'\033[31m'
else
    C_RESET=""; C_DIM=""; C_BOLD=""; C_CYAN=""; C_GREEN=""; C_YELLOW=""; C_RED=""
fi

# ------------------------------------------------------------------------------
# Hard-protected roots — swarf refuses to touch these or anything under them.
# ------------------------------------------------------------------------------
readonly -a PROTECTED=(
    "/" "/System" "/usr" "/bin" "/sbin" "/etc" "/var" "/private" "/Applications"
    "${HOME}/.ssh" "${HOME}/.gnupg" "${HOME}/Library/Keychains"
    "${HOME}/Documents" "${HOME}/Desktop" "${HOME}/Pictures" "${HOME}/Movies"
)

_is_protected() {
    local p="${1%/}"
    [[ -z "${p}" || "${p}" == "/" ]] && return 0
    [[ "${p}" == *".."* ]] && return 0
    local prot
    for prot in "${PROTECTED[@]}"; do
        prot="${prot%/}"
        [[ "${p}" == "${prot}" ]] && return 0
    done
    return 1
}

# ------------------------------------------------------------------------------
# Project-tree artifact types.  Each line: "name|marker_test"
# marker_test is eval'd with $parent set to the artifact's parent dir.
# "true" means the folder is always regenerable and safe (no marker needed).
# ------------------------------------------------------------------------------
_marker_ok() {
    local type="$1" dir="$2"
    local parent; parent="$(dirname "${dir}")"
    case "${type}" in
        node_modules) [[ -f "${parent}/package.json" ]] ;;
        target)       [[ -f "${parent}/Cargo.toml" ]] ;;
        build)        [[ -f "${parent}/build.gradle" || -f "${parent}/build.gradle.kts" \
                          || -f "${parent}/pom.xml" || -f "${parent}/CMakeLists.txt" \
                          || -f "${parent}/settings.gradle" || -f "${parent}/settings.gradle.kts" ]] ;;
        .gradle)      [[ -f "${parent}/build.gradle" || -f "${parent}/build.gradle.kts" \
                          || -f "${parent}/settings.gradle" || -f "${parent}/settings.gradle.kts" ]] ;;
        .dart_tool)   [[ -f "${parent}/pubspec.yaml" ]] ;;
        Pods)         [[ -f "${parent}/Podfile" ]] ;;
        .next|.turbo|.svelte-kit) [[ -f "${parent}/package.json" ]] ;;
        __pycache__|.pytest_cache|.mypy_cache|.ruff_cache) true ;;
        *) false ;;
    esac
}

# find-name predicates for the artifact dirs we look for in code trees
readonly -a ARTIFACT_NAMES=(
    node_modules target build .gradle .dart_tool Pods
    .next .turbo .svelte-kit __pycache__ .pytest_cache .mypy_cache .ruff_cache
)

# ------------------------------------------------------------------------------
# Apple / global dev caches — safe by location, no marker needed.
# Each line: "label|path"  (path may be a parent whose children are listed,
# marked by a trailing /*).
# ------------------------------------------------------------------------------
_apple_targets() {
    cat <<EOF
Xcode DerivedData|${HOME}/Library/Developer/Xcode/DerivedData/*
iOS DeviceSupport|${HOME}/Library/Developer/Xcode/iOS DeviceSupport/*
watchOS DeviceSupport|${HOME}/Library/Developer/Xcode/watchOS DeviceSupport/*
tvOS DeviceSupport|${HOME}/Library/Developer/Xcode/tvOS DeviceSupport/*
Simulator caches|${HOME}/Library/Developer/CoreSimulator/Caches
SwiftPM cache|${HOME}/Library/Caches/org.swift.swiftpm
CocoaPods cache|${HOME}/Library/Caches/CocoaPods
Gradle cache|${HOME}/.gradle/caches
npm cache|${HOME}/.npm/_cacache
Yarn cache|${HOME}/Library/Caches/Yarn
pip cache|${HOME}/Library/Caches/pip
EOF
}

# ------------------------------------------------------------------------------
# Helpers
# ------------------------------------------------------------------------------
_du_kb() { du -sk "$1" 2>/dev/null | awk '{print $1}'; }

_age_days() {
    local mtime now
    mtime="$(stat -f %m "$1" 2>/dev/null || echo 0)"
    now="$(date +%s)"
    echo $(( (now - mtime) / 86400 ))
}

_human() { # KB -> human
    local kb="${1:-0}"
    awk -v k="${kb}" 'BEGIN{
        b=k*1024; split("B KB MB GB TB",u," "); i=1;
        while(b>=1024 && i<5){b/=1024;i++}
        printf (b>=10||i==1)?"%.0f %s":"%.1f %s", b, u[i]
    }'
}

# Default scan roots: common dev dirs that exist, else cwd.
_default_roots() {
    local -a candidates=(
        "${HOME}/Developer" "${HOME}/code" "${HOME}/Code" "${HOME}/projects"
        "${HOME}/Projects" "${HOME}/src" "${HOME}/work" "${HOME}/repos" "${HOME}/dev"
    )
    local found=0 d
    for d in "${candidates[@]}"; do
        if [[ -d "${d}" ]]; then printf '%s\n' "${d}"; found=1; fi
    done
    [[ "${found}" -eq 0 ]] && printf '%s\n' "${PWD}"
}

# ------------------------------------------------------------------------------
# Collection — prints TSV rows: type \t kb \t age_days \t path
# ------------------------------------------------------------------------------
_collect_project() {
    local -a roots=("$@")
    local -a expr=()
    local n
    for n in "${ARTIFACT_NAMES[@]}"; do
        expr+=( -name "${n}" -o )
    done
    unset 'expr[${#expr[@]}-1]'  # drop trailing -o

    local root
    for root in "${roots[@]}"; do
        [[ -d "${root}" ]] || continue
        # Prune Library/.Trash; match artifact dirs and don't descend into them.
        while IFS= read -r dir; do
            [[ -z "${dir}" ]] && continue
            local base; base="$(basename "${dir}")"
            _is_protected "${dir}" && continue
            _marker_ok "${base}" "${dir}" || continue
            local kb; kb="$(_du_kb "${dir}")"; [[ -z "${kb}" ]] && continue
            [[ "${kb}" -lt 1024 ]] && continue   # skip < 1 MB
            printf '%s\t%s\t%s\t%s\n' "${base}" "${kb}" "$(_age_days "${dir}")" "${dir}"
        done < <(
            find "${root}" \
                \( -name Library -o -name .Trash -o -name .git \) -prune -o \
                -type d \( "${expr[@]}" \) -prune -print 2>/dev/null
        )
    done
}

_collect_apple() {
    local line label path
    while IFS='|' read -r label path; do
        [[ -z "${label}" ]] && continue
        if [[ "${path}" == *'/*' ]]; then
            local base="${path%/*}"
            [[ -d "${base}" ]] || continue
            local child
            while IFS= read -r child; do
                [[ -z "${child}" ]] && continue
                _is_protected "${child}" && continue
                local kb; kb="$(_du_kb "${child}")"; [[ -z "${kb}" ]] && continue
                [[ "${kb}" -lt 1024 ]] && continue
                printf '%s\t%s\t%s\t%s\n' "${label}" "${kb}" "$(_age_days "${child}")" "${child}"
            done < <(find "${base}" -mindepth 1 -maxdepth 1 2>/dev/null)
        else
            [[ -e "${path}" ]] || continue
            _is_protected "${path}" && continue
            local kb; kb="$(_du_kb "${path}")"; [[ -z "${kb}" ]] && continue
            [[ "${kb}" -lt 1024 ]] && continue
            printf '%s\t%s\t%s\t%s\n' "${label}" "${kb}" "$(_age_days "${path}")" "${path}"
        fi
    done < <(_apple_targets)
}

# ------------------------------------------------------------------------------
# Filters (applied to a TSV stream on stdin)
# ------------------------------------------------------------------------------
_apply_filters() {
    awk -F'\t' -v older="${OPT_OLDER}" -v minkb="${OPT_MINKB}" -v types="${OPT_TYPES}" '
        BEGIN { nt=split(types, T, ","); }
        {
            if (older > 0 && $3+0 < older) next;
            if (minkb > 0 && $2+0 < minkb) next;
            if (nt > 0 && types != "") {
                ok=0; for(i=1;i<=nt;i++) if($1==T[i]) ok=1;
                if(!ok) next;
            }
            print;
        }'
}

# ------------------------------------------------------------------------------
# Render a sorted table + return total KB via global _TOTAL_KB
# ------------------------------------------------------------------------------
_TOTAL_KB=0
_render() {
    local rows; rows="$(cat)"
    _TOTAL_KB=0
    if [[ -z "${rows}" ]]; then
        printf '%s  nothing reclaimable with the current filters.%s\n' "${C_DIM}" "${C_RESET}"
        return
    fi
    # sort by size desc
    rows="$(printf '%s\n' "${rows}" | sort -t$'\t' -k2,2nr)"
    printf '%s  %-22s %10s %8s  %s%s\n' "${C_BOLD}" "TYPE" "SIZE" "AGE" "PATH" "${C_RESET}"
    local type kb age path
    while IFS=$'\t' read -r type kb age path; do
        [[ -z "${type}" ]] && continue
        _TOTAL_KB=$(( _TOTAL_KB + kb ))
        local short="${path/#${HOME}/~}"
        local agestr; agestr="${age}d"
        local agecol="${C_DIM}"
        [[ "${age}" -ge 90 ]] && agecol="${C_YELLOW}"
        [[ "${age}" -ge 180 ]] && agecol="${C_RED}"
        printf '  %s%-22s%s %10s %s%7s%s  %s\n' \
            "${C_CYAN}" "${type}" "${C_RESET}" \
            "$(_human "${kb}")" "${agecol}" "${agestr}" "${C_RESET}" "${short}"
    done <<< "${rows}"
    printf '%s  %-22s %10s%s\n' "${C_BOLD}${C_GREEN}" "RECLAIMABLE" "$(_human "${_TOTAL_KB}")" "${C_RESET}"
}

# ------------------------------------------------------------------------------
# Trash one path (recoverable). --delete makes it permanent.
# ------------------------------------------------------------------------------
_trash_one() {
    local path="$1"
    if _is_protected "${path}"; then return 1; fi
    [[ -e "${path}" ]] || return 1
    if [[ "${OPT_PERMANENT}" -eq 1 ]]; then
        rm -rf -- "${path}" 2>/dev/null
        return $?
    fi
    mkdir -p "${TRASH_DIR}" 2>/dev/null || true
    local base; base="$(basename "${path}")"
    local dest="${TRASH_DIR}/${base}"
    if [[ -e "${dest}" ]]; then dest="${TRASH_DIR}/${base}.$(date +%Y%m%d_%H%M%S)"; fi
    mv -- "${path}" "${dest}" 2>/dev/null
}

# ------------------------------------------------------------------------------
# Commands
# ------------------------------------------------------------------------------
cmd_scan() {
    local -a roots=("$@")
    [[ "${#roots[@]}" -eq 0 ]] && IFS=$'\n' read -r -d '' -a roots < <(_default_roots && printf '\0')

    printf '%sswarf%s scanning %s%s%s\n\n' "${C_BOLD}" "${C_RESET}" \
        "${C_DIM}" "${roots[*]/#${HOME}/~}" "${C_RESET}"

    local stream
    if [[ "${OPT_NO_APPLE}" -eq 0 ]]; then
        stream="$( { _collect_project "${roots[@]}"; _collect_apple; } | _apply_filters )" || true
    else
        stream="$( _collect_project "${roots[@]}" | _apply_filters )" || true
    fi
    _render <<< "${stream}"
    echo
    printf '%sRun%s %sswarf clean%s%s to move these to Trash (recoverable).%s\n' \
        "${C_DIM}" "${C_RESET}" "${C_BOLD}" "${C_RESET}" "${C_DIM}" "${C_RESET}"
}

cmd_clean() {
    local -a roots=("$@")
    [[ "${#roots[@]}" -eq 0 ]] && IFS=$'\n' read -r -d '' -a roots < <(_default_roots && printf '\0')

    local stream
    if [[ "${OPT_NO_APPLE}" -eq 0 ]]; then
        stream="$( { _collect_project "${roots[@]}"; _collect_apple; } | _apply_filters )" || true
    else
        stream="$( _collect_project "${roots[@]}" | _apply_filters )" || true
    fi
    _render <<< "${stream}"
    [[ "${_TOTAL_KB}" -eq 0 ]] && return 0
    echo

    if [[ "${OPT_DRYRUN}" -eq 1 ]]; then
        printf '%s[dry-run]%s nothing was moved.\n' "${C_YELLOW}" "${C_RESET}"
        return 0
    fi

    local verb="move to Trash (recoverable)"
    [[ "${OPT_PERMANENT}" -eq 1 ]] && verb="${C_RED}PERMANENTLY DELETE${C_RESET}"
    if [[ "${OPT_YES}" -eq 0 ]]; then
        printf 'About to %s %s of artifacts. Continue? [y/N] ' "${verb}" "$(_human "${_TOTAL_KB}")"
        local reply; read -r reply
        [[ "${reply}" =~ ^[Yy]$ ]] || { echo "Aborted."; return 0; }
    fi

    local ok=0 freed=0 type kb age path
    while IFS=$'\t' read -r type kb age path; do
        [[ -z "${path}" ]] && continue
        if _trash_one "${path}"; then
            ok=$(( ok + 1 )); freed=$(( freed + kb ))
            printf '  %s✓%s %s\n' "${C_GREEN}" "${C_RESET}" "${path/#${HOME}/~}"
        else
            printf '  %s✗%s %s\n' "${C_RED}" "${C_RESET}" "${path/#${HOME}/~}"
        fi
    done <<< "${stream}"
    echo
    printf '%sReclaimed %s across %d items.%s\n' \
        "${C_BOLD}${C_GREEN}" "$(_human "${freed}")" "${ok}" "${C_RESET}"
    [[ "${OPT_PERMANENT}" -eq 0 ]] && \
        printf '%sRecover anything from Trash within 30 days.%s\n' "${C_DIM}" "${C_RESET}"
}

usage() {
    cat <<EOF
${C_BOLD}swarf${C_RESET} v${SWARF_VERSION} — reclaim a Mac developer's disk space, safely.

${C_BOLD}USAGE${C_RESET}
  ${SELF_NAME} scan  [roots...] [filters]   read-only; show what's reclaimable
  ${SELF_NAME} clean [roots...] [filters]   move matches to Trash (asks first)

${C_BOLD}ROOTS${C_RESET}
  Directories to scan for project artifacts. Defaults to common dev dirs
  (~/Developer, ~/code, ~/projects, ~/src, …) or the current directory.

${C_BOLD}FILTERS${C_RESET}
  --older-than DAYS   only artifacts not modified in DAYS days
  --min-size MB       only artifacts at least MB megabytes
  --type T1,T2        only these types (e.g. node_modules,target)
  --no-apple          skip Xcode/Simulator/global caches; project trees only

${C_BOLD}CLEAN OPTIONS${C_RESET}
  --dry-run           show what would move; touch nothing
  --yes               don't ask for confirmation
  --delete            permanently delete instead of moving to Trash

${C_BOLD}WHAT IT TOUCHES${C_RESET}
  Project trees: node_modules, target, build, .gradle, .dart_tool, Pods,
                 .next, .turbo, .svelte-kit, __pycache__, .pytest/.mypy/.ruff_cache
                 — each only when a real project marker (package.json, Cargo.toml,
                 Podfile, …) sits next to it.
  Apple/global:  Xcode DerivedData, iOS/watchOS/tvOS DeviceSupport, Simulator
                 caches, SwiftPM, CocoaPods, Gradle/npm/Yarn/pip caches.

  Trash-first by default. Marker-verified. It never deletes a folder by name alone.

${C_BOLD}EXAMPLES${C_RESET}
  ${SELF_NAME} scan
  ${SELF_NAME} scan ~/work --type node_modules --older-than 90
  ${SELF_NAME} clean --older-than 180 --yes
EOF
}

# ------------------------------------------------------------------------------
# Arg parsing
# ------------------------------------------------------------------------------
OPT_OLDER=0; OPT_MINKB=0; OPT_TYPES=""; OPT_NO_APPLE=0
OPT_DRYRUN=0; OPT_YES=0; OPT_PERMANENT=0
CMD=""; ROOTS=()

main() {
    [[ $# -eq 0 ]] && { usage; exit 0; }
    case "$1" in
        scan|clean) CMD="$1"; shift ;;
        -h|--help) usage; exit 0 ;;
        -v|--version) echo "${SELF_NAME} ${SWARF_VERSION}"; exit 0 ;;
        *) usage; exit 1 ;;
    esac

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --older-than) OPT_OLDER="${2:-0}"; shift 2 ;;
            --min-size)   OPT_MINKB=$(( ${2:-0} * 1024 )); shift 2 ;;
            --type)       OPT_TYPES="${2:-}"; shift 2 ;;
            --no-apple)   OPT_NO_APPLE=1; shift ;;
            --dry-run)    OPT_DRYRUN=1; shift ;;
            --yes|-y)     OPT_YES=1; shift ;;
            --delete)     OPT_PERMANENT=1; shift ;;
            --no-color)   shift ;;  # handled at color init via NO_COLOR env
            -h|--help)    usage; exit 0 ;;
            -*)           printf 'unknown option: %s\n' "$1" >&2; exit 1 ;;
            *)            ROOTS+=("$1"); shift ;;
        esac
    done

    case "${CMD}" in
        scan)  cmd_scan "${ROOTS[@]}" ;;
        clean) cmd_clean "${ROOTS[@]}" ;;
    esac
}

main "$@"
